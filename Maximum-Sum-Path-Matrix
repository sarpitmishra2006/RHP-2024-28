import java.util.*;

class Main {
    public static void main(String args[]) {

        Scanner sc = new Scanner(System.in);

        // Read number of rows and columns
        int rows = sc.nextInt();
        int cols = sc.nextInt();

        // Input matrix
        int matrix[][] = new int[rows][cols];

        for (int i = 0; i < rows; i++) {
            for (int j = 0; j < cols; j++) {
                matrix[i][j] = sc.nextInt();
            }
        }

        // Store maximum sums up to current column
        int dp[] = new int[rows];

        // Initialize with first column values
        for (int i = 0; i < rows; i++) {
            dp[i] = matrix[i][0];
        }

        // Process remaining columns
        for (int col = 1; col < cols; col++) {

            int newDp[] = new int[rows];

            for (int row = 0; row < rows; row++) {

                int best = Integer.MIN_VALUE;

                // Find maximum value from previous column
                // excluding the same row
                for (int prevRow = 0; prevRow < rows; prevRow++) {

                    if (prevRow != row) {

                        int sum = dp[prevRow] + matrix[row][col];

                        if (sum > best) {
                            best = sum;
                        }
                    }
                }

                newDp[row] = best;
            }

            dp = newDp;
        }

        // Find overall maximum sum
        int answer = Integer.MIN_VALUE;

        for (int value : dp) {
            if (value > answer) {
                answer = value;
            }
        }

        // Print result
        System.out.println(answer);
    }
}
